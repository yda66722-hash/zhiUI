local zhiUI = {}
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local Parent = gethui and gethui() or CoreGui:FindFirstChild("RobloxGui") or game.Players.LocalPlayer:WaitForChild("PlayerGui")

local Theme = {
    Main = Color3.fromRGB(20, 20, 20),
    Sidebar = Color3.fromRGB(25, 25, 25),
    Accent = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 255, 120)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(200, 255, 0))
    }),
    Button = Color3.fromRGB(35, 35, 35),
    Text = Color3.fromRGB(255, 255, 255)
}

local function MakeDraggable(obj)
    local dragging, dragStart, startPos
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = obj.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    obj.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

function zhiUI:CreateWindow(config)
    local Lib = { CurrentTab = nil }
    local Title = config.Title or "zhiUI"
    
    local ScreenGui = Instance.new("ScreenGui", Parent)
    ScreenGui.Name = "zhiUI_" .. math.random(100, 999)

    local MainFrame = Instance.new("Frame", ScreenGui)
    MainFrame.Size = UDim2.fromOffset(480, 320)
    MainFrame.Position = UDim2.fromScale(0.5, 0.5)
    MainFrame.AnchorPoint = Vector2.new(0.5, 0.5)
    MainFrame.BackgroundColor3 = Theme.Main
    MainFrame.BorderSizePixel = 0
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 10)
    MakeDraggable(MainFrame)

    local Sidebar = Instance.new("Frame", MainFrame)
    Sidebar.Size = UDim2.new(0, 140, 1, 0)
    Sidebar.BackgroundColor3 = Theme.Sidebar
    Sidebar.BorderSizePixel = 0
    Instance.new("UICorner", Sidebar).CornerRadius = UDim.new(0, 10)
    
    local SideLayout = Instance.new("UIListLayout", Sidebar)
    SideLayout.Padding = UDim.new(0, 5)
    SideLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    Instance.new("UIPadding", Sidebar).PaddingTop = UDim.new(0, 10)

    local ContentHolder = Instance.new("Frame", MainFrame)
    ContentHolder.Position = UDim2.new(0, 150, 0, 10)
    ContentHolder.Size = UDim2.new(1, -160, 1, -20)
    ContentHolder.BackgroundTransparency = 1

    local MiniFrame = Instance.new("TextButton", ScreenGui)
    MiniFrame.Size = UDim2.fromOffset(200, 38)
    MiniFrame.Position = UDim2.new(0.5, -100, 0, 40)
    MiniFrame.BackgroundColor3 = Theme.Main
    MiniFrame.Visible = false
    MiniFrame.Text = ""
    Instance.new("UICorner", MiniFrame).CornerRadius = UDim.new(1, 0)
    local MiniStroke = Instance.new("UIStroke", MiniFrame)
    MiniStroke.Thickness = 2
    local MiniGrad = Instance.new("UIGradient", MiniStroke)
    MiniGrad.Color = Theme.Accent
    MakeDraggable(MiniFrame)

    local MiniLabel = Instance.new("TextLabel", MiniFrame)
    MiniLabel.Size = UDim2.new(1, 0, 1, 0)
    MiniLabel.Text = "Open " .. Title
    MiniLabel.TextColor3 = Theme.Text
    MiniLabel.BackgroundTransparency = 1
    MiniLabel.Font = Enum.Font.GothamBold
    MiniLabel.TextSize = 12

    local function Toggle()
        MainFrame.Visible = not MainFrame.Visible
        MiniFrame.Visible = not MainFrame.Visible
    end
    MiniFrame.MouseButton1Click:Connect(Toggle)

    function Lib:AddTab(tabName)
        local TabBtn = Instance.new("TextButton", Sidebar)
        TabBtn.Size = UDim2.new(0.9, 0, 0, 35)
        TabBtn.BackgroundColor3 = Theme.Button
        TabBtn.Text = tabName
        TabBtn.TextColor3 = Theme.Text
        TabBtn.Font = Enum.Font.Gotham
        Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 6)

        local Page = Instance.new("ScrollingFrame", ContentHolder)
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.BackgroundTransparency = 1
        Page.Visible = false
        Page.ScrollBarThickness = 0
        Instance.new("UIListLayout", Page).Padding = UDim.new(0, 8)

        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(ContentHolder:GetChildren()) do v.Visible = false end
            Page.Visible = true
        end)

        if not Lib.CurrentTab then 
            Lib.CurrentTab = Page
            Page.Visible = true 
        end

        local TabMethods = {}
        function TabMethods:AddButton(text, callback)
            local b = Instance.new("TextButton", Page)
            b.Size = UDim2.new(0.95, 0, 0, 35)
            b.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            b.Text = text
            b.TextColor3 = Theme.Text
            b.Font = Enum.Font.Gotham
            Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
            b.MouseButton1Click:Connect(callback)
        end
        return TabMethods
    end

    task.spawn(function()
        while task.wait(0.05) do MiniGrad.Rotation = MiniGrad.Rotation + 3 end
    end)

    return Lib
end

return zhiUI