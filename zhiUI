-- [[ zhiUI Framework - Final Background & Jelly Version ]] --
local zhiUI = {}
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local Parent = gethui and gethui() or CoreGui:FindFirstChild("RobloxGui") or game.Players.LocalPlayer:WaitForChild("PlayerGui")

-- 清理旧 UI
for _, v in pairs(Parent:GetChildren()) do
    if v.Name:sub(1,6) == "zhiUI_" then v:Destroy() end
end

local Theme = {
    Main = Color3.fromRGB(25, 25, 25),
    Sidebar = Color3.fromRGB(32, 32, 32),
    Accent = Color3.fromRGB(0, 122, 255),
    Text = Color3.fromRGB(255, 255, 255),
    TextSecondary = Color3.fromRGB(160, 160, 160)
}

-- 果冻点击效果
local function JellyClick(obj)
    obj.MouseButton1Down:Connect(function()
        TweenService:Create(obj, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Size = UDim2.new(0.9, 0, 0, 45)}):Play()
    end)
    obj.MouseButton1Up:Connect(function()
        TweenService:Create(obj, TweenInfo.new(0.4, Enum.EasingStyle.Elastic), {Size = UDim2.new(0.95, 0, 0, 50)}):Play()
    end)
end

-- 拖拽功能
local function MakeDraggable(dragPart, mainPart)
    local dragging, dragStart, startPos
    dragPart.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true dragStart = input.Position startPos = mainPart.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            mainPart.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
end

function zhiUI:CreateWindow(config)
    local Lib = { CurrentTab = nil }
    local TitleText = config.Title or "zhiUI Hub"
    local BgID = config.Image or "" 

    local ScreenGui = Instance.new("ScreenGui", Parent)
    ScreenGui.Name = "zhiUI_" .. math.random(1,1000)
    ScreenGui.ResetOnSpawn = false
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling -- 确保 ZIndex 生效

    -- 屏幕适配
    local UIScale = Instance.new("UIScale", ScreenGui)
    UIScale.Scale = (workspace.CurrentCamera.ViewportSize.X < 800) and 0.8 or 1

    -- [ 主窗口 ] --
    local Main = Instance.new("Frame", ScreenGui)
    local MainSize = UDim2.fromOffset(550, 380)
    Main.Size = MainSize
    Main.Position = UDim2.fromScale(0.5, 0.5)
    Main.AnchorPoint = Vector2.new(0.5, 0.5)
    Main.BackgroundColor3 = Theme.Main
    Main.ClipsDescendants = true
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 12)

    -- 背景图处理 (强制置底)
    if BgID ~= "" then
        local BgLabel = Instance.new("ImageLabel", Main)
        BgLabel.Name = "Background"
        BgLabel.Size = UDim2.fromScale(1, 1)
        BgLabel.Image = BgID
        BgLabel.ScaleType = Enum.ScaleType.Crop
        BgLabel.ZIndex = -10 -- 极低层级
        Instance.new("UICorner", BgLabel).CornerRadius = UDim.new(0, 12)
        
        local DarkFilter = Instance.new("Frame", Main)
        DarkFilter.Size = UDim2.fromScale(1, 1)
        DarkFilter.BackgroundColor3 = Color3.new(0, 0, 0)
        DarkFilter.BackgroundTransparency = 0.4
        DarkFilter.ZIndex = -9 -- 仅高于背景图
        Instance.new("UICorner", DarkFilter).CornerRadius = UDim.new(0, 12)
    end

    -- [ 胶囊小窗 ] --
    local Mini = Instance.new("Frame", ScreenGui)
    Mini.Size = UDim2.fromOffset(200, 45)
    Mini.Position = UDim2.new(0.5, -100, 0, 50)
    Mini.BackgroundColor3 = Theme.Main
    Mini.Visible = false
    Instance.new("UICorner", Mini).CornerRadius = UDim.new(1, 0)
    
    local DragBtn = Instance.new("TextLabel", Mini)
    DragBtn.Size = UDim2.new(0, 45, 1, 0)
    DragBtn.Text = "✢"
    DragBtn.TextColor3 = Theme.TextSecondary
    DragBtn.BackgroundTransparency = 1
    DragBtn.TextSize = 20
    
    local OpenBtn = Instance.new("TextButton", Mini)
    OpenBtn.Size = UDim2.new(1, -45, 1, 0)
    OpenBtn.Position = UDim2.fromOffset(45, 0)
    OpenBtn.Text = "Open UI"
    OpenBtn.TextColor3 = Theme.Text
    OpenBtn.BackgroundTransparency = 1
    OpenBtn.Font = Enum.Font.GothamBold
    
    MakeDraggable(DragBtn, Mini)
    MakeDraggable(Main, Main)

    -- [ 折叠果冻动画 ] --
    local function Toggle(show)
        if show then
            Main.Visible = true
            Main.Size = UDim2.fromOffset(0, 0)
            TweenService:Create(Main, TweenInfo.new(0.6, Enum.EasingStyle.Elastic), {Size = MainSize}):Play()
            Mini.Visible = false
        else
            TweenService:Create(Main, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Size = UDim2.fromOffset(0, 0)}):Play()
            task.wait(0.2)
            Main.Visible = false
            Mini.Visible = true
        end
    end

    OpenBtn.MouseButton1Click:Connect(function() Toggle(true) end)

    -- 顶部导航
    local TopBar = Instance.new("Frame", Main)
    TopBar.Size = UDim2.new(1, 0, 0, 50)
    TopBar.BackgroundTransparency = 1
    
    local Close = Instance.new("TextButton", TopBar)
    Close.Size = UDim2.fromOffset(12, 12)
    Close.Position = UDim2.fromOffset(15, 19)
    Close.BackgroundColor3 = Color3.fromRGB(255, 95, 87)
    Close.Text = ""
    Instance.new("UICorner", Close).CornerRadius = UDim.new(1, 0)
    Close.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

    local Hide = Instance.new("TextButton", TopBar)
    Hide.Size = UDim2.fromOffset(12, 12)
    Hide.Position = UDim2.fromOffset(35, 19)
    Hide.BackgroundColor3 = Color3.fromRGB(255, 189, 46)
    Hide.Text = ""
    Instance.new("UICorner", Hide).CornerRadius = UDim.new(1, 0)
    Hide.MouseButton1Click:Connect(function() Toggle(false) end)

    -- 内容容器
    local Sidebar = Instance.new("Frame", Main)
    Sidebar.Size = UDim2.new(0, 150, 1, -50)
    Sidebar.Position = UDim2.fromOffset(0, 50)
    Sidebar.BackgroundColor3 = Theme.Sidebar
    Sidebar.BackgroundTransparency = 0.5
    Instance.new("UIListLayout", Sidebar).HorizontalAlignment = Enum.HorizontalAlignment.Center

    local Container = Instance.new("Frame", Main)
    Container.Size = UDim2.new(1, -160, 1, -60)
    Container.Position = UDim2.fromOffset(155, 55)
    Container.BackgroundTransparency = 1

    function Lib:AddTab(name)
        local TabBtn = Instance.new("TextButton", Sidebar)
        TabBtn.Size = UDim2.new(0.9, 0, 0, 40)
        TabBtn.BackgroundTransparency = 1
        TabBtn.Text = name
        TabBtn.TextColor3 = Theme.TextSecondary
        TabBtn.Font = Enum.Font.GothamBold

        local Page = Instance.new("ScrollingFrame", Container)
        Page.Size = UDim2.fromScale(1, 1)
        Page.BackgroundTransparency = 1
        Page.Visible = false
        Page.ScrollBarThickness = 0
        Instance.new("UIListLayout", Page).Padding = UDim.new(0, 8)

        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Container:GetChildren()) do v.Visible = false end
            for _, v in pairs(Sidebar:GetChildren()) do if v:IsA("TextButton") then v.TextColor3 = Theme.TextSecondary end end
            Page.Visible = true
            TabBtn.TextColor3 = Theme.Text
        end)

        if not Lib.CurrentTab then Lib.CurrentTab = Page Page.Visible = true TabBtn.TextColor3 = Theme.Text end

        local El = {}
        function El:AddButton(txt, cb)
            local b = Instance.new("TextButton", Page)
            b.Size = UDim2.new(0.95, 0, 0, 45)
            b.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            b.BackgroundTransparency = 0.3
            b.Text = txt
            b.TextColor3 = Theme.Text
            Instance.new("UICorner", b).CornerRadius = UDim.new(0, 8)
            JellyClick(b)
            b.MouseButton1Click:Connect(cb)
        end
        return El
    end
    return Lib
end

return zhiUI