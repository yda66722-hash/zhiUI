local UIS = game:GetService("UserInputService")
local TS = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

local PaperUI = {
    Themes = {
        Main = Color3.fromRGB(10, 10, 12),
        Accent = Color3.fromRGB(0, 255, 255),
        Secondary = Color3.fromRGB(20, 20, 25),
        Text = Color3.fromRGB(240, 240, 240),
        Danger = Color3.fromRGB(255, 60, 60)
    }
}

function PaperUI:Create(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props) do
        if k ~= "Parent" then inst[k] = v end
    end
    inst.Parent = props.Parent
    return inst
end

function PaperUI:Init(cfg)
    local config = cfg or {Name = "Paper Ultra"}
    local Screen = self:Create("ScreenGui", {Name = "Paper_"..math.random(100,999), Parent = CoreGui, IgnoreGuiInset = true})
    
    local Main = self:Create("Frame", {
        Name = "Main",
        Size = UDim2.new(0, 560, 0, 390),
        Position = UDim2.new(0.5, -280, 0.5, -195),
        BackgroundColor3 = self.Themes.Main,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Parent = Screen
    })
    
    self:Create("UICorner", {CornerRadius = UDim.new(0, 10), Parent = Main})
    self:Create("UIStroke", {Color = self.Themes.Accent, Thickness = 1.6, Transparency = 0.4, Parent = Main})

    local dragging, dragInput, dragStart, startPos
    Main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = Main.Position
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
            local delta = input.Position - dragStart
            TS:Create(Main, TweenInfo.new(0.12, Enum.EasingStyle.Quint), {
                Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            }):Play()
        end
    end)
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)

    local Sidebar = self:Create("Frame", {
        Size = UDim2.new(0, 165, 1, 0),
        BackgroundColor3 = self.Themes.Secondary,
        BorderSizePixel = 0,
        ZIndex = 2,
        Parent = Main
    })
    self:Create("UICorner", {CornerRadius = UDim.new(0, 10), Parent = Sidebar})
    
    local Title = self:Create("TextLabel", {
        Size = UDim2.new(1, 0, 0, 55),
        Text = config.Name,
        TextColor3 = self.Themes.Accent,
        Font = Enum.Font.GothamBold,
        TextSize = 17,
        BackgroundTransparency = 1,
        ZIndex = 3,
        Parent = Sidebar
    })

    local BtnContainer = self:Create("ScrollingFrame", {
        Size = UDim2.new(1, 0, 1, -65),
        Position = UDim2.new(0, 0, 0, 55),
        BackgroundTransparency = 1,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        ScrollBarThickness = 0,
        ZIndex = 3,
        Parent = Sidebar
    })
    self:Create("UIListLayout", {Padding = UDim.new(0, 6), HorizontalAlignment = "Center", Parent = BtnContainer})

    local Content = self:Create("Frame", {
        Size = UDim2.new(1, -175, 1, -50),
        Position = UDim2.new(0, 170, 0, 45),
        BackgroundTransparency = 1,
        ZIndex = 2,
        Parent = Main
    })

    local TopBar = self:Create("Frame", {
        Size = UDim2.new(1, -165, 0, 40),
        Position = UDim2.new(0, 165, 0, 0),
        BackgroundTransparency = 1,
        ZIndex = 4,
        Parent = Main
    })

    local Close = self:Create("TextButton", {
        Size = UDim2.new(0, 30, 0, 25),
        Position = UDim2.new(1, -35, 0, 8),
        BackgroundColor3 = self.Themes.Danger,
        Text = "×",
        TextColor3 = self.Themes.Text,
        Font = Enum.Font.GothamBold,
        TextSize = 18,
        ZIndex = 5,
        Parent = TopBar
    })
    self:Create("UICorner", {CornerRadius = UDim.new(0, 5), Parent = Close})

    local Min = self:Create("TextButton", {
        Size = UDim2.new(0, 30, 0, 25),
        Position = UDim2.new(1, -70, 0, 8),
        BackgroundColor3 = Color3.fromRGB(45, 45, 50),
        Text = "-",
        TextColor3 = self.Themes.Text,
        Font = Enum.Font.GothamBold,
        TextSize = 18,
        ZIndex = 5,
        Parent = TopBar
    })
    self:Create("UICorner", {CornerRadius = UDim.new(0, 5), Parent = Min})

    local IsMin = false
    Min.MouseButton1Click:Connect(function()
        IsMin = not IsMin
        local targetSize = IsMin and UDim2.new(0, 165, 0, 55) or UDim2.new(0, 560, 0, 390)
        TS:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Back), {Size = targetSize}):Play()
        Min.Text = IsMin and "+" or "-"
        Content.Visible = not IsMin
    end)

    Close.MouseButton1Click:Connect(function()
        TS:Create(Main, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0,0,0,0), BackgroundTransparency = 1}):Play()
        task.wait(0.25)
        Screen:Destroy()
    end)

    local Tabs = {}

    function Tabs:SetBackground(id, trans)
        local bg = PaperUI:Create("ImageLabel", {
            Size = UDim2.new(1, 0, 1, 0),
            Image = "rbxassetid://" .. tostring(id:match("%d+")),
            ImageTransparency = trans or 0.5,
            ScaleType = "Crop",
            BackgroundColor3 = Color3.new(0,0,0),
            ZIndex = 1,
            Parent = Main
        })
        PaperUI:Create("UICorner", {CornerRadius = UDim.new(0, 10), Parent = bg})
    end

    function Tabs:NewTab(name)
        local TButton = PaperUI:Create("TextButton", {
            Size = UDim2.new(0, 145, 0, 38),
            BackgroundColor3 = PaperUI.Themes.Main,
            Text = name,
            TextColor3 = PaperUI.Themes.Text,
            Font = Enum.Font.GothamMedium,
            TextSize = 14,
            AutoButtonColor = false,
            ZIndex = 4,
            Parent = BtnContainer
        })
        PaperUI:Create("UICorner", {CornerRadius = UDim.new(0, 6), Parent = TButton})
        PaperUI:Create("UIStroke", {Color = PaperUI.Themes.Accent, Thickness = 1, Transparency = 0.8, Parent = TButton})

        local Page = PaperUI:Create("ScrollingFrame", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Visible = false,
            ScrollBarThickness = 2,
            ZIndex = 3,
            Parent = Content
        })
        PaperUI:Create("UIListLayout", {Padding = UDim.new(0, 10), Parent = Page})

        TButton.MouseButton1Click:Connect(function()
            for _, v in pairs(Content:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end
            for _, v in pairs(BtnContainer:GetChildren()) do if v:IsA("TextButton") then TS:Create(v, TweenInfo.new(0.2), {TextColor3 = PaperUI.Themes.Text}):Play() end end
            Page.Visible = true
            TS:Create(TButton, TweenInfo.new(0.2), {TextColor3 = PaperUI.Themes.Accent}):Play()
        end)

        local Modules = {}

        function Modules:AddButton(txt, cb)
            local b = PaperUI:Create("TextButton", {
                Size = UDim2.new(1, -10, 0, 40),
                BackgroundColor3 = PaperUI.Themes.Secondary,
                Text = txt,
                TextColor3 = PaperUI.Themes.Text,
                Font = Enum.Font.Gotham,
                TextSize = 13,
                ZIndex = 4,
                Parent = Page
            })
            PaperUI:Create("UICorner", {Parent = b})
            b.MouseButton1Click:Connect(cb)
        end

        function Modules:AddToggle(txt, def, cb)
            local t = PaperUI:Create("Frame", {Size = UDim2.new(1, -10, 0, 45), BackgroundColor3 = PaperUI.Themes.Secondary, ZIndex = 4, Parent = Page})
            PaperUI:Create("UICorner", {Parent = t})
            local l = PaperUI:Create("TextLabel", {Size = UDim2.new(1, -60, 1, 0), Position = UDim2.new(0, 15, 0, 0), Text = txt, BackgroundTransparency = 1, TextColor3 = PaperUI.Themes.Text, TextXAlignment = "Left", ZIndex = 5, Parent = t})
            local s = def
            local b = PaperUI:Create("TextButton", {Size = UDim2.new(0, 45, 0, 22), Position = UDim2.new(1, -55, 0.5, -11), Text = "", BackgroundColor3 = s and PaperUI.Themes.Accent or Color3.fromRGB(50,50,55), ZIndex = 5, Parent = t})
            PaperUI:Create("UICorner", {CornerRadius = UDim.new(1,0), Parent = b})
            b.MouseButton1Click:Connect(function()
                s = not s
                TS:Create(b, TweenInfo.new(0.2), {BackgroundColor3 = s and PaperUI.Themes.Accent or Color3.fromRGB(50,50,55)}):Play()
                cb(s)
            end)
        end

        return Modules
    end

    return Tabs
end

return PaperUI