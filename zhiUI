-- [[ zhiUI Framework - iOS Pure Edition ]] --
-- 只有库定义，不含任何调用逻辑
-- 适配手机，支持大字号、拖拽和自动画布

local zhiUI = {}
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local Parent = gethui and gethui() or CoreGui:FindFirstChild("RobloxGui") or game.Players.LocalPlayer:WaitForChild("PlayerGui")

local Theme = {
    Main = Color3.fromRGB(0, 0, 0), 
    Secondary = Color3.fromRGB(28, 28, 30), 
    Accent = Color3.fromRGB(10, 132, 255), 
    Text = Color3.fromRGB(255, 255, 255),
    TextSecondary = Color3.fromRGB(174, 174, 178),
    FontTitle = Enum.Font.GothamBold,
    FontText = Enum.Font.GothamMedium,
    TextSizeTitle = 32,
    TextSizeButton = 20
}

local function MakeDraggable(obj)
    local dragging, dragStart, startPos
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = obj.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    obj.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
end

function zhiUI:CreateWindow(title)
    local ScreenGui = Instance.new("ScreenGui", Parent)
    ScreenGui.Name = "zhiUI_Mobile_" .. math.random(1,1000)
    
    local MainFrame = Instance.new("Frame", ScreenGui)
    MainFrame.Size = UDim2.fromOffset(380, 500)
    MainFrame.Position = UDim2.fromScale(0.5, 0.5)
    MainFrame.AnchorPoint = Vector2.new(0.5, 0.5)
    MainFrame.BackgroundColor3 = Theme.Main
    MainFrame.BorderSizePixel = 0
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 15)
    MakeDraggable(MainFrame)

    local Content = Instance.new("ScrollingFrame", MainFrame)
    Content.Size = UDim2.new(1, 0, 1, 0)
    Content.BackgroundTransparency = 1
    Content.ScrollBarThickness = 0
    Content.CanvasSize = UDim2.new(0, 0, 0, 0)
    Content.AutomaticCanvasSize = Enum.AutomaticSize.Y
    
    local Layout = Instance.new("UIListLayout", Content)
    Layout.Padding = UDim.new(0, 10)
    Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    Instance.new("UIPadding", Content).PaddingTop = UDim.new(0, 20)

    local TitleLabel = Instance.new("TextLabel", Content)
    TitleLabel.Size = UDim2.new(1, -40, 0, 60)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = title
    TitleLabel.TextColor3 = Theme.Text
    TitleLabel.Font = Theme.FontTitle
    TitleLabel.TextSize = Theme.TextSizeTitle
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

    local Methods = {}
    function Methods:AddButton(name, sub, callback)
        local Btn = Instance.new("TextButton", Content)
        Btn.Size = UDim2.new(1, -30, 0, 70)
        Btn.BackgroundColor3 = Theme.Secondary
        Btn.Text = ""
        Btn.AutoButtonColor = false
        Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 12)

        local t = Instance.new("TextLabel", Btn)
        t.Size = UDim2.new(1, -40, 0, 30)
        t.Position = UDim2.fromOffset(15, 12)
        t.BackgroundTransparency = 1
        t.Text = name
        t.TextColor3 = Theme.Text
        t.Font = Theme.FontText
        t.TextSize = Theme.TextSizeButton
        t.TextXAlignment = Enum.TextXAlignment.Left

        local s = Instance.new("TextLabel", Btn)
        s.Size = UDim2.new(1, -40, 0, 20)
        s.Position = UDim2.fromOffset(15, 38)
        s.BackgroundTransparency = 1
        s.Text = sub or "Tap to execute"
        s.TextColor3 = Theme.TextSecondary
        s.Font = Theme.FontText
        s.TextSize = 14
        s.TextXAlignment = Enum.TextXAlignment.Left

        Btn.MouseButton1Click:Connect(function()
            TweenService:Create(Btn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(50,50,50)}):Play()
            task.wait(0.1)
            TweenService:Create(Btn, TweenInfo.new(0.1), {BackgroundColor3 = Theme.Secondary}):Play()
            callback()
        end)
    end
    
    function Methods:Destroy()
        ScreenGui:Destroy()
    end

    return Methods
end

return zhiUI