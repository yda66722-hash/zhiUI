-- [[ zhiUI Framework - + Icon Update & Slider Support ]] --
local zhiUI = {}
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local Parent = gethui and gethui() or CoreGui:FindFirstChild("RobloxGui") or game.Players.LocalPlayer:WaitForChild("PlayerGui")

-- 清理旧UI
for _, v in pairs(Parent:GetChildren()) do
    if v.Name:sub(1,6) == "zhiUI_" then v:Destroy() end
end

local Theme = {
    Main = Color3.fromRGB(25, 25, 25),
    Sidebar = Color3.fromRGB(32, 32, 32),
    Accent = Color3.fromRGB(0, 122, 255),
    Text = Color3.fromRGB(255, 255, 255),
    TextSecondary = Color3.fromRGB(160, 160, 160),
    Trans = 0.1
}

-- [ 动画辅助 ] --
local function JellyClick(obj)
    obj.MouseButton1Down:Connect(function()
        TweenService:Create(obj, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Size = UDim2.new(0.9, 0, 0, 45)}):Play()
    end)
    obj.MouseButton1Up:Connect(function()
        TweenService:Create(obj, TweenInfo.new(0.4, Enum.EasingStyle.Elastic), {Size = UDim2.new(0.95, 0, 0, 50)}):Play()
    end)
end

local function MakeDraggable(dragPart, mainPart)
    local dragging, dragStart, startPos
    dragPart.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true dragStart = input.Position startPos = mainPart.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            mainPart.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
end

function zhiUI:CreateWindow(config)
    local Lib = { CurrentTab = nil }
    local TitleText = config.Title or "zhiUI Hub"
    
    local ScreenGui = Instance.new("ScreenGui", Parent)
    ScreenGui.Name = "zhiUI_" .. math.random(1,1000)
    ScreenGui.ResetOnSpawn = false

    local UIScale = Instance.new("UIScale", ScreenGui)
    UIScale.Scale = (workspace.CurrentCamera.ViewportSize.X < 800) and 0.8 or 1

    -- [ 胶囊小窗 - 使用纯代码绘制 + 号 ] --
    local Mini = Instance.new("Frame", ScreenGui)
    Mini.Size = UDim2.fromOffset(180, 45)
    Mini.Position = UDim2.new(0.5, -90, 0, 50)
    Mini.BackgroundColor3 = Theme.Main
    Mini.BackgroundTransparency = 0.1
    Mini.Visible = false
    Mini.ClipsDescendants = true
    Instance.new("UICorner", Mini).CornerRadius = UDim.new(1, 0)
    
    -- 绘制 + 号区域 (拖拽区)
    local PlusIconArea = Instance.new("Frame", Mini)
    PlusIconArea.Size = UDim2.fromOffset(45, 45)
    PlusIconArea.BackgroundTransparency = 1
    
    -- 横线
    local Plus_H = Instance.new("Frame", PlusIconArea)
    Plus_H.Size = UDim2.fromOffset(16, 2)
    Plus_H.Position = UDim2.fromScale(0.5, 0.5)
    Plus_H.AnchorPoint = Vector2.new(0.5, 0.5)
    Plus_H.BackgroundColor3 = Theme.Text
    Plus_H.BorderSizePixel = 0
    
    -- 竖线
    local Plus_V = Instance.new("Frame", PlusIconArea)
    Plus_V.Size = UDim2.fromOffset(2, 16)
    Plus_V.Position = UDim2.fromScale(0.5, 0.5)
    Plus_V.AnchorPoint = Vector2.new(0.5, 0.5)
    Plus_V.BackgroundColor3 = Theme.Text
    Plus_V.BorderSizePixel = 0
    
    local ClickOpen = Instance.new("TextButton", Mini)
    ClickOpen.Size = UDim2.new(1, -45, 1, 0)
    ClickOpen.Position = UDim2.fromOffset(45, 0)
    ClickOpen.BackgroundTransparency = 1
    ClickOpen.Text = "Open UI"
    ClickOpen.TextColor3 = Theme.Text
    ClickOpen.Font = Enum.Font.GothamBold
    ClickOpen.TextSize = 14
    
    MakeDraggable(PlusIconArea, Mini)

    -- [ 主窗口 ] --
    local Main = Instance.new("Frame", ScreenGui)
    local MainSize = UDim2.fromOffset(550, 380)
    Main.Size = MainSize
    Main.Position = UDim2.fromScale(0.5, 0.5)
    Main.AnchorPoint = Vector2.new(0.5, 0.5)
    Main.BackgroundColor3 = Theme.Main
    Main.BackgroundTransparency = Theme.Trans
    Main.ClipsDescendants = true
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 14)
    MakeDraggable(Main, Main)

    -- 折叠逻辑
    local function ToggleUI(show)
        if show then
            Main.Visible = true
            Main.Size = UDim2.fromOffset(0, 0)
            TweenService:Create(Main, TweenInfo.new(0.5, Enum.EasingStyle.Elastic), {Size = MainSize}):Play()
            Mini.Visible = false
        else
            TweenService:Create(Main, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Size = UDim2.fromOffset(0, 0)}):Play()
            task.wait(0.2)
            Main.Visible = false
            Mini.Visible = true
        end
    end

    ClickOpen.MouseButton1Click:Connect(function() ToggleUI(true) end)

    -- 顶部按钮 (黄色按钮触发折叠)
    local TopBar = Instance.new("Frame", Main)
    TopBar.Size = UDim2.new(1, 0, 0, 50)
    TopBar.BackgroundTransparency = 1

    local MinimizeBtn = Instance.new("TextButton", TopBar)
    MinimizeBtn.Size = UDim2.fromOffset(13, 13)
    MinimizeBtn.Position = UDim2.fromOffset(40, 19)
    MinimizeBtn.BackgroundColor3 = Color3.fromRGB(255, 189, 46)
    MinimizeBtn.Text = ""
    Instance.new("UICorner", MinimizeBtn).CornerRadius = UDim.new(1, 0)
    MinimizeBtn.MouseButton1Click:Connect(function() ToggleUI(false) end)

    -- 侧边栏与容器
    local Sidebar = Instance.new("Frame", Main)
    Sidebar.Size = UDim2.new(0, 150, 1, -50)
    Sidebar.Position = UDim2.fromOffset(0, 50)
    Sidebar.BackgroundColor3 = Theme.Sidebar
    Sidebar.BackgroundTransparency = 0.2
    Instance.new("UIListLayout", Sidebar).HorizontalAlignment = Enum.HorizontalAlignment.Center

    local Container = Instance.new("Frame", Main)
    Container.Size = UDim2.new(1, -170, 1, -70)
    Container.Position = UDim2.fromOffset(160, 60)
    Container.BackgroundTransparency = 1

    function Lib:AddTab(name)
        local TabBtn = Instance.new("TextButton", Sidebar)
        TabBtn.Size = UDim2.new(0.9, 0, 0, 40)
        TabBtn.BackgroundTransparency = 1
        TabBtn.Text = name
        TabBtn.TextColor3 = Theme.TextSecondary
        TabBtn.Font = Enum.Font.GothamBold
        
        local Page = Instance.new("ScrollingFrame", Container)
        Page.Size = UDim2.fromScale(1, 1)
        Page.BackgroundTransparency = 1
        Page.Visible = false
        Page.ScrollBarThickness = 0
        Instance.new("UIListLayout", Page).Padding = UDim.new(0, 10)

        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Container:GetChildren()) do v.Visible = false end
            Page.Visible = true
        end)
        if not Lib.CurrentTab then Lib.CurrentTab = Page Page.Visible = true end

        local Elements = {}
        
        -- 滑动条功能 (带实时数字显示)
        function Elements:AddSlider(text, min, max, default, callback)
            local SliderFrame = Instance.new("Frame", Page)
            SliderFrame.Size = UDim2.new(0.95, 0, 0, 60)
            SliderFrame.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            SliderFrame.BackgroundTransparency = 0.4
            Instance.new("UICorner", SliderFrame).CornerRadius = UDim.new(0, 10)

            local Label = Instance.new("TextLabel", SliderFrame)
            Label.Size = UDim2.new(1, -20, 0, 25)
            Label.Position = UDim2.fromOffset(10, 5)
            Label.Text = text .. ": " .. default
            Label.TextColor3 = Theme.Text
            Label.Font = Enum.Font.GothamBold
            Label.TextSize = 14
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.BackgroundTransparency = 1

            local SliderBack = Instance.new("Frame", SliderFrame)
            SliderBack.Size = UDim2.new(0.9, 0, 0, 4)
            SliderBack.Position = UDim2.new(0.05, 0, 0.75, 0)
            SliderBack.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
            Instance.new("UICorner", SliderBack)

            local SliderFill = Instance.new("Frame", SliderBack)
            SliderFill.Size = UDim2.fromScale((default - min) / (max - min), 1)
            SliderFill.BackgroundColor3 = Theme.Accent
            Instance.new("UICorner", SliderFill)

            local dragging = false
            local function Update()
                local inputPos = UserInputService:GetMouseLocation().X
                local barPos = SliderBack.AbsolutePosition.X
                local barWidth = SliderBack.AbsoluteSize.X
                local percent = math.clamp((inputPos - barPos) / barWidth, 0, 1)
                
                SliderFill.Size = UDim2.fromScale(percent, 1)
                local val = math.floor(min + (max - min) * percent)
                Label.Text = text .. ": " .. val
                callback(val)
            end

            SliderBack.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true Update()
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    Update()
                end
            end)

            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end)
        end

        function Elements:AddButton(txt, cb)
            local b = Instance.new("TextButton", Page)
            b.Size = UDim2.new(0.95, 0, 0, 45)
            b.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            b.Text = txt
            b.TextColor3 = Theme.Text
            Instance.new("UICorner", b).CornerRadius = UDim.new(0, 10)
            JellyClick(b)
            b.MouseButton1Click:Connect(cb)
        end

        return Elements
    end
    return Lib
end

return zhiUI