local UIS = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

local PaperLib = {}

function PaperLib:CreateWindow(Config)
    local Name = Config.Name or "Paper Script"
    local Sub = Config.SubTitle or "Version 1.0"
    local Icon = Config.Icon or "rbxassetid://10734933213"

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "Paper_UI"
    ScreenGui.Parent = CoreGui
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    local Main = Instance.new("Frame")
    Main.Name = "Main"
    Main.Size = UDim2.new(0, 580, 0, 380)
    Main.Position = UDim2.new(0.5, -290, 0.5, -190)
    Main.BackgroundColor3 = Color3.fromRGB(12, 12, 12)
    Main.BorderSizePixel = 0
    Main.Parent = ScreenGui

    local MainCorner = Instance.new("UICorner")
    MainCorner.CornerRadius = UDim.new(0, 10)
    MainCorner.Parent = Main

    local MainStroke = Instance.new("UIStroke")
    MainStroke.Color = Color3.fromRGB(35, 35, 35)
    MainStroke.Thickness = 1
    MainStroke.Parent = Main

    local Sidebar = Instance.new("Frame")
    Sidebar.Name = "Sidebar"
    Sidebar.Size = UDim2.new(0, 180, 1, 0)
    Sidebar.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
    Sidebar.BorderSizePixel = 0
    Sidebar.Parent = Main

    local SideCorner = Instance.new("UICorner")
    SideCorner.CornerRadius = UDim.new(0, 10)
    SideCorner.Parent = Sidebar

    local InfoContainer = Instance.new("Frame")
    InfoContainer.Size = UDim2.new(1, 0, 0, 70)
    InfoContainer.BackgroundTransparency = 1
    InfoContainer.Parent = Sidebar

    local AppIcon = Instance.new("ImageLabel")
    AppIcon.Size = UDim2.new(0, 32, 0, 32)
    AppIcon.Position = UDim2.new(0, 15, 0, 15)
    AppIcon.Image = Icon
    AppIcon.BackgroundTransparency = 1
    AppIcon.Parent = InfoContainer

    local AppTitle = Instance.new("TextLabel")
    AppTitle.Size = UDim2.new(1, -60, 0, 20)
    AppTitle.Position = UDim2.new(0, 55, 0, 13)
    AppTitle.BackgroundTransparency = 1
    AppTitle.Text = Name
    AppTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
    AppTitle.TextSize = 15
    AppTitle.Font = Enum.Font.GothamBold
    AppTitle.TextXAlignment = Enum.TextXAlignment.Left
    AppTitle.Parent = InfoContainer

    local AppSub = Instance.new("TextLabel")
    AppSub.Size = UDim2.new(1, -60, 0, 15)
    AppSub.Position = UDim2.new(0, 55, 0, 30)
    AppSub.BackgroundTransparency = 1
    AppSub.Text = Sub
    AppSub.TextColor3 = Color3.fromRGB(150, 150, 150)
    AppSub.TextSize = 11
    AppSub.Font = Enum.Font.Gotham
    AppSub.TextXAlignment = Enum.TextXAlignment.Left
    AppSub.Parent = InfoContainer

    local TabContainer = Instance.new("ScrollingFrame")
    TabContainer.Size = UDim2.new(1, 0, 1, -80)
    TabContainer.Position = UDim2.new(0, 0, 0, 75)
    TabContainer.BackgroundTransparency = 1
    TabContainer.ScrollBarThickness = 0
    TabContainer.Parent = Sidebar

    local TabList = Instance.new("UIListLayout")
    TabList.Parent = TabContainer
    TabList.Padding = UDim.new(0, 4)
    TabList.HorizontalAlignment = Enum.HorizontalAlignment.Center

    local PageContainer = Instance.new("Frame")
    PageContainer.Size = UDim2.new(1, -200, 1, -20)
    PageContainer.Position = UDim2.new(0, 190, 0, 10)
    PageContainer.BackgroundTransparency = 1
    PageContainer.Parent = Main

    local Tabs = {}
    local FirstTab = true

    function Tabs:CreateTab(TabName, TabIcon)
        local TabButton = Instance.new("TextButton")
        TabButton.Size = UDim2.new(0.9, 0, 0, 34)
        TabButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        TabButton.BackgroundTransparency = 1
        TabButton.Text = "          " .. TabName
        TabButton.TextColor3 = Color3.fromRGB(180, 180, 180)
        TabButton.TextSize = 13
        TabButton.Font = Enum.Font.GothamMedium
        TabButton.TextXAlignment = Enum.TextXAlignment.Left
        TabButton.Parent = TabContainer

        local TabBtnIcon = Instance.new("ImageLabel")
        TabBtnIcon.Size = UDim2.new(0, 16, 0, 16)
        TabBtnIcon.Position = UDim2.new(0, 12, 0.5, -8)
        TabBtnIcon.Image = TabIcon or ""
        TabBtnIcon.ImageColor3 = Color3.fromRGB(180, 180, 180)
        TabBtnIcon.BackgroundTransparency = 1
        TabBtnIcon.Parent = TabButton

        local TabBtnCorner = Instance.new("UICorner")
        TabBtnCorner.CornerRadius = UDim.new(0, 6)
        TabBtnCorner.Parent = TabButton

        local Page = Instance.new("ScrollingFrame")
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.BackgroundTransparency = 1
        Page.Visible = false
        Page.ScrollBarThickness = 0
        Page.Parent = PageContainer

        local PageList = Instance.new("UIListLayout")
        PageList.Parent = Page
        PageList.Padding = UDim.new(0, 8)

        if FirstTab then
            Page.Visible = true
            TabButton.BackgroundTransparency = 0.9
            TabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            TabBtnIcon.ImageColor3 = Color3.fromRGB(255, 255, 255)
            FirstTab = false
        end

        TabButton.MouseButton1Click:Connect(function()
            for _, v in pairs(PageContainer:GetChildren()) do
                if v:IsA("ScrollingFrame") then v.Visible = false end
            end
            for _, v in pairs(TabContainer:GetChildren()) do
                if v:IsA("TextButton") then
                    TweenService:Create(v, TweenInfo.new(0.2), {BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(180, 180, 180)}):Play()
                    TweenService:Create(v:FindFirstChildOfClass("ImageLabel"), TweenInfo.new(0.2), {ImageColor3 = Color3.fromRGB(180, 180, 180)}):Play()
                end
            end
            Page.Visible = true
            TweenService:Create(TabButton, TweenInfo.new(0.2), {BackgroundTransparency = 0.9, TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
            TweenService:Create(TabBtnIcon, TweenInfo.new(0.2), {ImageColor3 = Color3.fromRGB(255, 255, 255)}):Play()
        end)

        local Elements = {}

        function Elements:CreateButton(Text, Callback)
            local Button = Instance.new("TextButton")
            Button.Size = UDim2.new(1, -10, 0, 40)
            Button.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            Button.Text = "    " .. Text
            Button.TextColor3 = Color3.fromRGB(230, 230, 230)
            Button.TextXAlignment = Enum.TextXAlignment.Left
            Button.Font = Enum.Font.Gotham
            Button.TextSize = 13
            Button.Parent = Page

            local BtnCorner = Instance.new("UICorner")
            BtnCorner.CornerRadius = UDim.new(0, 6)
            BtnCorner.Parent = Button

            local BtnStroke = Instance.new("UIStroke")
            BtnStroke.Color = Color3.fromRGB(40, 40, 40)
            BtnStroke.Thickness = 1
            BtnStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            BtnStroke.Parent = Button

            Button.MouseEnter:Connect(function()
                TweenService:Create(Button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(35, 35, 35)}):Play()
            end)
            Button.MouseLeave:Connect(function()
                TweenService:Create(Button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(25, 25, 25)}):Play()
            end)
            Button.MouseButton1Click:Connect(function()
                Callback()
            end)
        end

        return Elements
    end

    local dragging, dragInput, dragStart, startPos
    Main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = Main.Position
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    RunService.RenderStepped:Connect(function()
        if dragging and dragInput then
            local delta = dragInput.Position - dragStart
            Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    return Tabs
end

return PaperLib