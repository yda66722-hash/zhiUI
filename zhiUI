-- [[ zhiUI Framework - Bubble Slider Edition ]] --
local zhiUI = {}
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local Parent = gethui and gethui() or CoreGui:FindFirstChild("RobloxGui") or game.Players.LocalPlayer:WaitForChild("PlayerGui")

-- 清理旧UI
for _, v in pairs(Parent:GetChildren()) do
    if v.Name:sub(1,6) == "zhiUI_" then v:Destroy() end
end

local Theme = {
    Main = Color3.fromRGB(25, 25, 25),
    Sidebar = Color3.fromRGB(32, 32, 32),
    Accent = Color3.fromRGB(0, 122, 255),
    Text = Color3.fromRGB(255, 255, 255),
    TextSecondary = Color3.fromRGB(160, 160, 160),
    Trans = 0.1
}

-- [ 动画辅助 ] --
local function JellyTab(obj)
    obj.MouseEnter:Connect(function()
        TweenService:Create(obj, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Size = UDim2.new(0.9, 0, 0, 48)}):Play()
    end)
    obj.MouseLeave:Connect(function()
        TweenService:Create(obj, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Size = UDim2.new(0.85, 0, 0, 45)}):Play()
    end)
end

local function JellyClick(obj)
    obj.MouseButton1Down:Connect(function()
        TweenService:Create(obj, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Size = UDim2.new(0.9, 0, 0, 45)}):Play()
    end)
    obj.MouseButton1Up:Connect(function()
        TweenService:Create(obj, TweenInfo.new(0.4, Enum.EasingStyle.Elastic), {Size = UDim2.new(0.95, 0, 0, 50)}):Play()
    end)
end

local function MakeDraggable(dragPart, mainPart)
    local dragging, dragStart, startPos
    dragPart.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true dragStart = input.Position startPos = mainPart.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            mainPart.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
end

function zhiUI:CreateWindow(config)
    local Lib = { CurrentTab = nil }
    local TitleText = config.Title or "zhiUI Hub"

    local ScreenGui = Instance.new("ScreenGui", Parent)
    ScreenGui.Name = "zhiUI_" .. math.random(1,1000)
    ScreenGui.ResetOnSpawn = false

    local UIScale = Instance.new("UIScale", ScreenGui)
    local function UpdateScale() UIScale.Scale = (workspace.CurrentCamera.ViewportSize.X < 800) and 0.75 or 1 end
    UpdateScale()
    workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(UpdateScale)

    -- 主窗口绘制 (省略部分重复的静态布局代码以保持简洁，逻辑与你提供的一致)
    local Main = Instance.new("Frame", ScreenGui)
    local MainSize = UDim2.fromOffset(550, 380)
    Main.Size = MainSize
    Main.Position = UDim2.fromScale(0.5, 0.5)
    Main.AnchorPoint = Vector2.new(0.5, 0.5)
    Main.BackgroundColor3 = Theme.Main
    Main.BackgroundTransparency = Theme.Trans
    Main.ClipsDescendants = true
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 14)
    MakeDraggable(Main, Main)

    -- 侧边栏与容器
    local Sidebar = Instance.new("Frame", Main)
    Sidebar.Size = UDim2.new(0, 160, 1, -50)
    Sidebar.Position = UDim2.fromOffset(0, 50)
    Sidebar.BackgroundColor3 = Theme.Sidebar
    Sidebar.BackgroundTransparency = 0.2
    Instance.new("UICorner", Sidebar).CornerRadius = UDim.new(0, 14)
    local SideLayout = Instance.new("UIListLayout", Sidebar)
    SideLayout.Padding = UDim.new(0, 5)
    SideLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center

    local Container = Instance.new("Frame", Main)
    Container.Size = UDim2.new(1, -180, 1, -70)
    Container.Position = UDim2.fromOffset(170, 60)
    Container.BackgroundTransparency = 1

    function Lib:AddTab(name)
        local TabBtn = Instance.new("TextButton", Sidebar)
        TabBtn.Size = UDim2.new(0.85, 0, 0, 45)
        TabBtn.BackgroundTransparency = 1
        TabBtn.Text = name
        TabBtn.TextColor3 = Theme.TextSecondary
        TabBtn.Font = Enum.Font.GothamBold
        TabBtn.TextSize = 16
        JellyTab(TabBtn)

        local Page = Instance.new("ScrollingFrame", Container)
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.BackgroundTransparency = 1
        Page.Visible = false
        Page.ScrollBarThickness = 0
        Instance.new("UIListLayout", Page).Padding = UDim.new(0, 10)

        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Container:GetChildren()) do v.Visible = false end
            for _, v in pairs(Sidebar:GetChildren()) do if v:IsA("TextButton") then v.TextColor3 = Theme.TextSecondary end end
            Page.Visible = true
            TabBtn.TextColor3 = Theme.Text
        end)

        if not Lib.CurrentTab then Lib.CurrentTab = Page Page.Visible = true TabBtn.TextColor3 = Theme.Text end

        local Elements = {}

        -- [ 核心更新：带气泡提示的滑动条 ] --
        function Elements:AddSlider(text, min, max, default, callback)
            local SliderFrame = Instance.new("Frame", Page)
            SliderFrame.Size = UDim2.new(0.95, 0, 0, 65)
            SliderFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            SliderFrame.BackgroundTransparency = 0.4
            Instance.new("UICorner", SliderFrame).CornerRadius = UDim.new(0, 10)

            local Label = Instance.new("TextLabel", SliderFrame)
            Label.Size = UDim2.new(1, 0, 0, 30)
            Label.Position = UDim2.fromOffset(15, 5)
            Label.BackgroundTransparency = 1
            Label.Text = text
            Label.TextColor3 = Theme.Text
            Label.Font = Enum.Font.GothamBold
            Label.TextSize = 15
            Label.TextXAlignment = Enum.TextXAlignment.Left

            local SliderBar = Instance.new("Frame", SliderFrame)
            SliderBar.Size = UDim2.new(0.9, 0, 0, 4)
            SliderBar.Position = UDim2.new(0.05, 0, 0, 48)
            SliderBar.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
            Instance.new("UICorner", SliderBar)

            local Fill = Instance.new("Frame", SliderBar)
            Fill.Size = UDim2.fromScale(math.clamp((default - min) / (max - min), 0, 1), 1)
            Fill.BackgroundColor3 = Theme.Accent
            Instance.new("UICorner", Fill)

            local SliderDot = Instance.new("Frame", Fill)
            SliderDot.Size = UDim2.fromOffset(16, 16)
            SliderDot.Position = UDim2.new(1, -8, 0.5, -8)
            SliderDot.BackgroundColor3 = Color3.new(1, 1, 1)
            Instance.new("UICorner", SliderDot).CornerRadius = UDim.new(1, 0)

            -- [ 气泡数值提示层 ] --
            local Bubble = Instance.new("Frame", SliderDot)
            Bubble.Size = UDim2.fromOffset(35, 22)
            Bubble.Position = UDim2.new(0.5, -17, 0, -28)
            Bubble.BackgroundColor3 = Theme.Accent
            Bubble.BackgroundTransparency = 1 -- 初始隐藏
            Instance.new("UICorner", Bubble).CornerRadius = UDim.new(0, 6)

            local BubbleText = Instance.new("TextLabel", Bubble)
            BubbleText.Size = UDim2.fromScale(1, 1)
            BubbleText.BackgroundTransparency = 1
            BubbleText.Text = tostring(default)
            BubbleText.TextColor3 = Color3.new(1, 1, 1)
            BubbleText.Font = Enum.Font.GothamBold
            BubbleText.TextSize = 12
            BubbleText.TextTransparency = 1 -- 初始隐藏

            -- 气泡小尖角 (装饰)
            local Arrow = Instance.new("Frame", Bubble)
            Arrow.Size = UDim2.fromOffset(8, 8)
            Arrow.Position = UDim2.new(0.5, -4, 1, -4)
            Arrow.Rotation = 45
            Arrow.BackgroundColor3 = Theme.Accent
            Arrow.BorderSizePixel = 0
            Arrow.BackgroundTransparency = 1

            local dragging = false
            local function UpdateSlider()
                local mousePos = UserInputService:GetMouseLocation().X
                local barPos = SliderBar.AbsolutePosition.X
                local barSize = SliderBar.AbsoluteSize.X
                local percent = math.clamp((mousePos - barPos) / barSize, 0, 1)
                
                local val = math.floor(min + (max - min) * percent)
                Fill.Size = UDim2.fromScale(percent, 1)
                BubbleText.Text = tostring(val)
                callback(val)
            end

            -- 交互效果
            SliderFrame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    -- 显示气泡动画
                    TweenService:Create(Bubble, TweenInfo.new(0.2), {BackgroundTransparency = 0, Position = UDim2.new(0.5, -17, 0, -32)}):Play()
                    TweenService:Create(Arrow, TweenInfo.new(0.2), {BackgroundTransparency = 0}):Play()
                    TweenService:Create(BubbleText, TweenInfo.new(0.2), {TextTransparency = 0}):Play()
                    UpdateSlider()
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    UpdateSlider()
                end
            end)

            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                    -- 隐藏气泡动画
                    TweenService:Create(Bubble, TweenInfo.new(0.2), {BackgroundTransparency = 1, Position = UDim2.new(0.5, -17, 0, -28)}):Play()
                    TweenService:Create(Arrow, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
                    TweenService:Create(BubbleText, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
                end
            end)
        end

        -- AddButton 和 AddToggle 逻辑保持不变...
        function Elements:AddButton(t, c) --[[ ... ]] end
        function Elements:AddToggle(t, d, c) --[[ ... ]] end

        return Elements
    end
    return Lib
end

return zhiUI