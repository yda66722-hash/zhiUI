local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Player = game.Players.LocalPlayer
local Mouse = Player:GetMouse()

local UI = {
    Theme = {
        Background = Color3.fromRGB(20, 20, 20),
        Sidebar = Color3.fromRGB(25, 25, 25),
        Accent = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 255, 100)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(200, 255, 50))
        }),
        Stroke = Color3.fromRGB(45, 45, 45),
        Text = Color3.fromRGB(255, 255, 255),
        Font = Enum.Font.GothamMedium
    }
}

-- [[ 工具函数：拖拽 ]] --
function UI:EnableDrag(frame)
    local dragging, dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    frame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
end

-- [[ 创建主 UI ]] --
function UI:Init()
    local ScreenGui = Instance.new("ScreenGui", Player.PlayerGui)
    ScreenGui.Name = "PaperExecutorUI"
    ScreenGui.ResetOnSpawn = false

    -- 1. 主窗口 (Main Window)
    local MainFrame = Instance.new("Frame")
    MainFrame.Size = UDim2.fromOffset(550, 350)
    MainFrame.Position = UDim2.fromScale(0.5, 0.5)
    MainFrame.AnchorPoint = Vector2.new(0.5, 0.5)
    MainFrame.BackgroundColor3 = self.Theme.Background
    MainFrame.BorderSizePixel = 0
    MainFrame.Visible = true
    MainFrame.Parent = ScreenGui

    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 12)
    local MainStroke = Instance.new("UIStroke", MainFrame)
    MainStroke.Color = self.Theme.Stroke
    MainStroke.Thickness = 1

    -- 2. 侧边栏 (Sidebar)
    local Sidebar = Instance.new("Frame", MainFrame)
    Sidebar.Size = UDim2.new(0, 160, 1, 0)
    Sidebar.BackgroundColor3 = self.Theme.Sidebar
    Sidebar.BorderSizePixel = 0
    Instance.new("UICorner", Sidebar).CornerRadius = UDim.new(0, 12)

    -- 3. 胶囊缩写窗 (Mini Window)
    local MiniFrame = Instance.new("TextButton", ScreenGui)
    MiniFrame.Size = UDim2.fromOffset(200, 40)
    MiniFrame.Position = UDim2.new(1, -220, 0, 50)
    MiniFrame.BackgroundColor3 = self.Theme.Background
    MiniFrame.Visible = false
    MiniFrame.Text = ""
    MiniFrame.AutoButtonColor = false

    Instance.new("UICorner", MiniFrame).CornerRadius = UDim.new(1, 0)
    local MiniStroke = Instance.new("UIStroke", MiniFrame)
    MiniStroke.Thickness = 2
    local MiniGradient = Instance.new("UIGradient", MiniStroke)
    MiniGradient.Color = self.Theme.Accent

    local MiniLabel = Instance.new("TextLabel", MiniFrame)
    MiniLabel.Size = UDim2.new(1, -60, 1, 0)
    MiniLabel.Position = UDim2.fromOffset(50, 0)
    MiniLabel.BackgroundTransparency = 1
    MiniLabel.Text = "Open .ftgs hub UI"
    MiniLabel.TextColor3 = self.Theme.Text
    MiniLabel.Font = self.Theme.Font
    MiniLabel.TextSize = 14
    MiniLabel.TextXAlignment = Enum.TextXAlignment.Left

    -- [[ 交互逻辑：切换状态 ]] --
    
    -- 缩小函数
    local function Minimize()
        MainFrame:TweenSize(UDim2.fromOffset(0, 0), "Out", "Quad", 0.3, true, function()
            MainFrame.Visible = false
            MiniFrame.Visible = true
            MiniFrame:TweenSize(UDim2.fromOffset(200, 40), "Out", "Back", 0.3)
        end)
    end

    -- 展开函数
    local function Maximize()
        MiniFrame:TweenSize(UDim2.fromOffset(0, 0), "In", "Quad", 0.2, true, function()
            MiniFrame.Visible = false
            MainFrame.Visible = true
            MainFrame:TweenSize(UDim2.fromOffset(550, 350), "Out", "Back", 0.3)
        end)
    end

    -- 绑定点击事件
    MiniFrame.MouseButton1Click:Connect(Maximize)
    
    -- 示例：按下右侧 Control 键缩小
    UserInputService.InputBegan:Connect(function(input)
        if input.KeyCode == Enum.KeyCode.RightControl then
            if MainFrame.Visible then Minimize() else Maximize() end
        end
    end)

    -- 启用拖拽
    self:EnableDrag(MainFrame)
    self:EnableDrag(MiniFrame)

    -- 简单的渐变旋转动画
    task.spawn(function()
        while task.wait(0.05) do
            MiniGradient.Rotation = MiniGradient.Rotation + 2
        end
    end)
end

UI:Init()