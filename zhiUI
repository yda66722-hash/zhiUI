-- [[ zhiUI Framework - Mac-iOS Hybrid ]] --
-- 还原 Mac 视觉 + iOS 大字体验
-- 红色: 关闭 | 黄色: 缩小至胶囊 | 绿色: 无

local zhiUI = {}
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local Parent = gethui and gethui() or CoreGui:FindFirstChild("RobloxGui") or game.Players.LocalPlayer:WaitForChild("PlayerGui")

-- 清理
for _, v in pairs(Parent:GetChildren()) do
    if v.Name:sub(1,6) == "zhiUI_" then v:Destroy() end
end

local Theme = {
    Main = Color3.fromRGB(25, 25, 25),
    Sidebar = Color3.fromRGB(33, 33, 33),
    Accent = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 255, 120)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(200, 255, 0))
    }),
    Text = Color3.fromRGB(255, 255, 255),
    TextSecondary = Color3.fromRGB(180, 180, 180)
}

local function MakeDraggable(obj)
    local dragging, dragStart, startPos
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true dragStart = input.Position startPos = obj.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    obj.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
end

function zhiUI:CreateWindow(config)
    local Lib = { CurrentTab = nil }
    local TitleText = config.Title or "zhiUI Hub"
    
    local ScreenGui = Instance.new("ScreenGui", Parent)
    ScreenGui.Name = "zhiUI_" .. math.random(1,1000)

    -- 胶囊小窗 (提前创建，用于缩小功能)
    local Mini = Instance.new("TextButton", ScreenGui)
    Mini.Size = UDim2.fromOffset(200, 40)
    Mini.Position = UDim2.new(0.5, -100, 0, 50)
    Mini.BackgroundColor3 = Theme.Main
    Mini.Visible = false
    Mini.Text = ""
    Instance.new("UICorner", Mini).CornerRadius = UDim.new(1, 0)
    local MiniStroke = Instance.new("UIStroke", Mini)
    MiniStroke.Thickness = 2
    local MiniGrad = Instance.new("UIGradient", MiniStroke)
    MiniGrad.Color = Theme.Accent
    
    local MiniLabel = Instance.new("TextLabel", Mini)
    MiniLabel.Size = UDim2.new(1, 0, 1, 0)
    MiniLabel.Text = "Open " .. TitleText
    MiniLabel.TextColor3 = Theme.Text
    MiniLabel.BackgroundTransparency = 1
    MiniLabel.Font = Enum.Font.GothamBold
    MiniLabel.TextSize = 14
    MakeDraggable(Mini)

    -- 主窗口
    local Main = Instance.new("Frame", ScreenGui)
    Main.Size = UDim2.fromOffset(500, 350)
    Main.Position = UDim2.fromScale(0.5, 0.5)
    Main.AnchorPoint = Vector2.new(0.5, 0.5)
    Main.BackgroundColor3 = Theme.Main
    Main.BorderSizePixel = 0
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 12)
    MakeDraggable(Main)

    -- 顶部栏 (放置红黄绿和标题)
    local TopBar = Instance.new("Frame", Main)
    TopBar.Size = UDim2.new(1, 0, 0, 45)
    TopBar.BackgroundTransparency = 1

    -- 红黄绿按钮
    local Buttons = {Color3.fromRGB(255, 70, 70), Color3.fromRGB(255, 190, 50), Color3.fromRGB(50, 215, 75)}
    for i, color in ipairs(Buttons) do
        local b = Instance.new("TextButton", TopBar)
        b.Size = UDim2.fromOffset(13, 13)
        b.Position = UDim2.fromOffset(15 + (i-1)*22, 16)
        b.BackgroundColor3 = color
        b.Text = ""
        Instance.new("UICorner", b).CornerRadius = UDim.new(1, 0)
        
        if i == 1 then -- 红: 关闭
            b.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)
        elseif i == 2 then -- 黄: 缩小
            b.MouseButton1Click:Connect(function() 
                Main.Visible = false Mini.Visible = true 
            end)
        end
    end
    
    Mini.MouseButton1Click:Connect(function()
        Main.Visible = true Mini.Visible = false
    end)

    -- 标题 (大字并靠右一点，不和按钮撞)
    local Title = Instance.new("TextLabel", TopBar)
    Title.Size = UDim2.new(1, -100, 1, 0)
    Title.Position = UDim2.fromOffset(85, 0)
    Title.BackgroundTransparency = 1
    Title.Text = TitleText
    Title.TextColor3 = Theme.Text
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 18 -- 大字
    Title.TextXAlignment = Enum.TextXAlignment.Left

    -- 侧边栏
    local Sidebar = Instance.new("Frame", Main)
    Sidebar.Size = UDim2.new(0, 150, 1, -45)
    Sidebar.Position = UDim2.fromOffset(0, 45)
    Sidebar.BackgroundColor3 = Theme.Sidebar
    Sidebar.BorderSizePixel = 0
    Instance.new("UICorner", Sidebar).CornerRadius = UDim.new(0, 12)

    local SideLayout = Instance.new("UIListLayout", Sidebar)
    SideLayout.Padding = UDim.new(0, 5)
    SideLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center

    -- 内容区
    local Container = Instance.new("Frame", Main)
    Container.Size = UDim2.new(1, -160, 1, -55)
    Container.Position = UDim2.fromOffset(155, 50)
    Container.BackgroundTransparency = 1

    function Lib:AddTab(name)
        local TabBtn = Instance.new("TextButton", Sidebar)
        TabBtn.Size = UDim2.new(0.9, 0, 0, 40) -- 侧边栏按钮也加大
        TabBtn.BackgroundTransparency = 1
        TabBtn.Text = name
        TabBtn.TextColor3 = Theme.TextSecondary
        TabBtn.Font = Enum.Font.GothamBold
        TabBtn.TextSize = 16 -- 大字
        
        local Page = Instance.new("ScrollingFrame", Container)
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.BackgroundTransparency = 1
        Page.Visible = false
        Page.ScrollBarThickness = 0
        local PageLayout = Instance.new("UIListLayout", Page)
        PageLayout.Padding = UDim.new(0, 10)

        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Container:GetChildren()) do v.Visible = false end
            for _, v in pairs(Sidebar:GetChildren()) do 
                if v:IsA("TextButton") then v.TextColor3 = Theme.TextSecondary end 
            end
            Page.Visible = true
            TabBtn.TextColor3 = Theme.Text
        end)

        if not Lib.CurrentTab then
            Lib.CurrentTab = Page
            Page.Visible = true
            TabBtn.TextColor3 = Theme.Text
        end

        local Elements = {}
        function Elements:AddButton(text, callback)
            local b = Instance.new("TextButton", Page)
            b.Size = UDim2.new(0.95, 0, 0, 50) -- 按钮加高
            b.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            b.Text = text
            b.TextColor3 = Theme.Text
            b.Font = Enum.Font.GothamBold
            b.TextSize = 18 -- 大字
            Instance.new("UICorner", b).CornerRadius = UDim.new(0, 10)
            
            b.MouseButton1Click:Connect(callback)
        end
        return Elements
    end

    task.spawn(function()
        while task.wait(0.05) do MiniGrad.Rotation = MiniGrad.Rotation + 3 end
    end)

    return Lib
end

return zhiUI