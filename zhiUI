local UIS = game:GetService("UserInputService")
local TS = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")

local PaperUI = {
    Themes = {
        Main = Color3.fromRGB(9, 9, 11),
        Accent = Color3.fromRGB(0, 255, 255),
        Secondary = Color3.fromRGB(18, 18, 22),
        Text = Color3.fromRGB(250, 250, 250),
        Placeholder = Color3.fromRGB(120, 120, 120)
    }
}

function PaperUI:Create(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props) do
        if k ~= "Parent" then inst[k] = v end
    end
    inst.Parent = props.Parent
    return inst
end

function PaperUI:Init(cfg)
    local config = cfg or {Name = "Paper Ultra"}
    local Screen = self:Create("ScreenGui", {Name = "Paper_"..math.random(100,999), Parent = CoreGui, IgnoreGuiInset = true})
    
    local Main = self:Create("Frame", {
        Name = "Main",
        Size = UDim2.new(0, 500, 0, 320),
        Position = UDim2.new(0.5, -250, 0.5, -160),
        BackgroundColor3 = self.Themes.Main,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Parent = Screen
    })
    
    self:Create("UICorner", {CornerRadius = UDim.new(0, 12), Parent = Main})
    self:Create("UIStroke", {Color = self.Themes.Accent, Thickness = 1.2, Transparency = 0.6, Parent = Main})

    local Minified = self:Create("TextButton", {
        Name = "Minified",
        Size = UDim2.new(0, 45, 0, 45),
        Position = UDim2.new(0.5, -22, 0.5, -22),
        BackgroundColor3 = self.Themes.Accent,
        Visible = false,
        Text = "P",
        Font = Enum.Font.GothamBold,
        TextColor3 = Color3.new(0,0,0),
        TextSize = 20,
        Parent = Screen
    })
    self:Create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = Minified})

    local function MakeDraggable(obj, target)
        local dragging, input, startPos, startInput
        obj.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                startInput = i.Position
                startPos = target.Position
                i.Changed:Connect(function()
                    if i.UserInputState == Enum.UserInputState.End then dragging = false end
                end)
            end
        end)
        UIS.InputChanged:Connect(function(i)
            if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
                local delta = i.Position - startInput
                TS:Create(target, TweenInfo.new(0.1, Enum.EasingStyle.Quint), {
                    Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
                }):Play()
            end
        end)
    end

    MakeDraggable(Main, Main)
    MakeDraggable(Minified, Minified)

    local Sidebar = self:Create("Frame", {
        Size = UDim2.new(0, 140, 1, 0),
        BackgroundColor3 = self.Themes.Secondary,
        BorderSizePixel = 0,
        Parent = Main
    })
    self:Create("UICorner", {CornerRadius = UDim.new(0, 12), Parent = Sidebar})

    local TopBar = self:Create("Frame", {
        Size = UDim2.new(1, -140, 0, 35),
        Position = UDim2.new(0, 140, 0, 0),
        BackgroundTransparency = 1,
        Parent = Main
    })

    local MinBtn = self:Create("TextButton", {
        Size = UDim2.new(0, 30, 0, 30),
        Position = UDim2.new(1, -35, 0, 5),
        BackgroundTransparency = 1,
        Text = "—",
        TextColor3 = self.Themes.Placeholder,
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        Parent = TopBar
    })

    MinBtn.MouseButton1Click:Connect(function()
        TS:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 0, 0, 0),
            Position = Minified.Position
        }):Play()
        task.wait(0.4)
        Main.Visible = false
        Minified.Visible = true
        TS:Create(Minified, TweenInfo.new(0.3, Enum.EasingStyle.ElasticOut), {Size = UDim2.new(0, 50, 0, 50)}):Play()
    end)

    Minified.MouseButton1Click:Connect(function()
        Minified.Visible = false
        Main.Visible = true
        TS:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 500, 0, 320)
        }):Play()
    end)

    local NavScroll = self:Create("ScrollingFrame", {
        Size = UDim2.new(1, 0, 1, -50),
        Position = UDim2.new(0, 0, 0, 45),
        BackgroundTransparency = 1,
        ScrollBarThickness = 0,
        Parent = Sidebar
    })
    self:Create("UIListLayout", {Padding = UDim.new(0, 4), HorizontalAlignment = "Center", Parent = NavScroll})

    local Content = self:Create("Frame", {
        Size = UDim2.new(1, -150, 1, -45),
        Position = UDim2.new(0, 145, 0, 40),
        BackgroundTransparency = 1,
        Parent = Main
    })

    local Tabs = {}

    function Tabs:NewTab(name)
        local Btn = PaperUI:Create("TextButton", {
            Size = UDim2.new(0, 120, 0, 32),
            BackgroundColor3 = Color3.fromRGB(25, 25, 30),
            Text = name,
            TextColor3 = PaperUI.Themes.Placeholder,
            Font = Enum.Font.GothamMedium,
            TextSize = 13,
            AutoButtonColor = false,
            Parent = NavScroll
        })
        PaperUI:Create("UICorner", {CornerRadius = UDim.new(0, 6), Parent = Btn})

        local Page = PaperUI:Create("ScrollingFrame", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Visible = false,
            ScrollBarThickness = 1,
            Parent = Content
        })
        PaperUI:Create("UIListLayout", {Padding = UDim.new(0, 8), Parent = Page})

        Btn.MouseButton1Click:Connect(function()
            for _, v in pairs(Content:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end
            for _, v in pairs(NavScroll:GetChildren()) do if v:IsA("TextButton") then TS:Create(v, TweenInfo.new(0.2), {TextColor3 = PaperUI.Themes.Placeholder}):Play() end end
            Page.Visible = true
            TS:Create(Btn, TweenInfo.new(0.2), {TextColor3 = PaperUI.Themes.Accent}):Play()
        end)

        local Modules = {}

        function Modules:AddButton(txt, cb)
            local b = PaperUI:Create("TextButton", {
                Size = UDim2.new(1, -5, 0, 38),
                BackgroundColor3 = PaperUI.Themes.Secondary,
                Text = txt,
                TextColor3 = PaperUI.Themes.Text,
                Font = Enum.Font.Gotham,
                TextSize = 13,
                Parent = Page
            })
            PaperUI:Create("UICorner", {Parent = b})
            b.MouseButton1Click:Connect(cb)
        end

        function Modules:AddToggle(txt, def, cb)
            local t = PaperUI:Create("Frame", {Size = UDim2.new(1, -5, 0, 38), BackgroundColor3 = PaperUI.Themes.Secondary, Parent = Page})
            PaperUI:Create("UICorner", {Parent = t})
            local l = PaperUI:Create("TextLabel", {Size = UDim2.new(1, -60, 1, 0), Position = UDim2.new(0, 12, 0, 0), Text = txt, BackgroundTransparency = 1, TextColor3 = PaperUI.Themes.Text, TextXAlignment = "Left", Parent = t})
            local s = def
            local btn = PaperUI:Create("TextButton", {Size = UDim2.new(0, 34, 0, 18), Position = UDim2.new(1, -45, 0.5, -9), Text = "", BackgroundColor3 = s and PaperUI.Themes.Accent or Color3.fromRGB(40,40,45), Parent = t})
            PaperUI:Create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = btn})
            btn.MouseButton1Click:Connect(function()
                s = not s
                TS:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = s and PaperUI.Themes.Accent or Color3.fromRGB(40,40,45)}):Play()
                cb(s)
            end)
        end

        return Modules
    end

    return Tabs
end

return PaperUI