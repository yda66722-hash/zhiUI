local UIS = game:GetService("UserInputService")
local TS = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")

local PaperUI = {
    Themes = {
        Main = Color3.fromRGB(11, 11, 12),
        Accent = Color3.fromRGB(0, 255, 200), -- 换个更高级的青绿色
        Secondary = Color3.fromRGB(20, 20, 23),
        Card = Color3.fromRGB(28, 28, 32),
        Text = Color3.fromRGB(240, 240, 245),
        SubText = Color3.fromRGB(140, 140, 150)
    },
    Anims = {
        Default = TweenInfo.new(0.3, Enum.EasingStyle.Quint),
        Quick = TweenInfo.new(0.15, Enum.EasingStyle.Quad)
    }
}

-- 内部工具：快速创建带属性的实例
function PaperUI:_make(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props) do
        if k ~= "Parent" then inst[k] = v end
    end
    inst.Parent = props.Parent
    return inst
end

-- 内部工具：添加交互反馈
function PaperUI:_addHover(obj, goal, original)
    obj.MouseEnter:Connect(function()
        TS:Create(obj, self.Anims.Quick, goal):Play()
    end)
    obj.MouseLeave:Connect(function()
        TS:Create(obj, self.Anims.Quick, original):Play()
    end)
end

function PaperUI:Init(cfg)
    local config = cfg or {Name = "Paper Ultra"}
    local Screen = self:_make("ScreenGui", {Name = "Paper_"..math.random(100), Parent = CoreGui, IgnoreGuiInset = true})
    
    local Main = self:_make("Frame", {
        Name = "Main",
        Size = UDim2.new(0, 550, 0, 350),
        Position = UDim2.new(0.5, -275, 0.5, -175),
        BackgroundColor3 = self.Themes.Main,
        BorderSizePixel = 0,
        Parent = Screen
    })
    
    self:_make("UICorner", {CornerRadius = UDim.new(0, 12), Parent = Main})
    local Stroke = self:_make("UIStroke", {Color = self.Themes.Accent, Thickness = 1, Transparency = 0.8, Parent = Main})

    -- 标题栏 (让拖拽更自然)
    local TitleBar = self:_make("Frame", {
        Size = UDim2.new(1, 0, 0, 40),
        BackgroundTransparency = 1,
        Parent = Main
    })

    local TitleLabel = self:_make("TextLabel", {
        Size = UDim2.new(1, -20, 1, 0),
        Position = UDim2.new(0, 15, 0, 0),
        Text = config.Name,
        TextColor3 = self.Themes.Text,
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        TextXAlignment = "Left",
        BackgroundTransparency = 1,
        Parent = TitleBar
    })

    -- 侧边栏
    local Sidebar = self:_make("Frame", {
        Size = UDim2.new(0, 160, 1, -40),
        Position = UDim2.new(0, 0, 0, 40),
        BackgroundColor3 = self.Themes.Secondary,
        BorderSizePixel = 0,
        Parent = Main
    })
    self:_make("UICorner", {CornerRadius = UDim.new(0, 12), Parent = Sidebar})

    local NavScroll = self:_make("ScrollingFrame", {
        Size = UDim2.new(1, 0, 1, -10),
        Position = UDim2.new(0, 0, 0, 5),
        BackgroundTransparency = 1,
        ScrollBarThickness = 0,
        Parent = Sidebar
    })
    self:_make("UIListLayout", {Padding = UDim.new(0, 4), HorizontalAlignment = "Center", Parent = NavScroll})
    self:_make("UIPadding", {PaddingTop = UDim.new(0, 5), Parent = NavScroll})

    -- 内容区
    local ContentContainer = self:_make("Frame", {
        Size = UDim2.new(1, -170, 1, -50),
        Position = UDim2.new(0, 170, 0, 45),
        BackgroundTransparency = 1,
        Parent = Main
    })

    -- 拖拽逻辑 (注入到标题栏)
    local function EnableDrag(gui)
        local dragging, startPos, startInput
        gui.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true; startInput = i.Position; startPos = Main.Position
            end
        end)
        UIS.InputChanged:Connect(function(i)
            if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
                local delta = i.Position - startInput
                TS:Create(Main, TweenInfo.new(0.1), {
                    Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
                }):Play()
            end
        end)
        UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    end
    EnableDrag(TitleBar)

    local Tabs = { Selected = nil }

    function Tabs:NewTab(name)
        local TabBtn = PaperUI:_make("TextButton", {
            Size = UDim2.new(0, 145, 0, 32),
            BackgroundColor3 = Color3.fromRGB(255, 255, 255),
            BackgroundTransparency = 1,
            Text = name,
            TextColor3 = PaperUI.Themes.SubText,
            Font = Enum.Font.GothamMedium,
            TextSize = 13,
            Parent = NavScroll
        })
        PaperUI:_make("UICorner", {CornerRadius = UDim.new(0, 6), Parent = TabBtn})
        
        local Page = PaperUI:_make("ScrollingFrame", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Visible = false,
            ScrollBarThickness = 2,
            ScrollBarImageColor3 = PaperUI.Themes.Accent,
            Parent = ContentContainer
        })
        PaperUI:_make("UIListLayout", {Padding = UDim.new(0, 8), Parent = Page})
        PaperUI:_make("UIPadding", {PaddingRight = UDim.new(0, 5), Parent = Page})

        TabBtn.MouseButton1Click:Connect(function()
            if Tabs.Selected == TabBtn then return end
            for _, v in pairs(ContentContainer:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end
            for _, v in pairs(NavScroll:GetChildren()) do 
                if v:IsA("TextButton") then 
                    TS:Create(v, PaperUI.Anims.Default, {BackgroundTransparency = 1, TextColor3 = PaperUI.Themes.SubText}):Play() 
                end 
            end
            Tabs.Selected = TabBtn
            Page.Visible = true
            TS:Create(TabBtn, PaperUI.Anims.Default, {BackgroundTransparency = 0.9, TextColor3 = PaperUI.Themes.Accent}):Play()
        end)

        -- 首次自动选中
        if not Tabs.Selected then 
            Page.Visible = true 
            Tabs.Selected = TabBtn
            TabBtn.TextColor3 = PaperUI.Themes.Accent
            TabBtn.BackgroundTransparency = 0.9
        end

        local Modules = {}

        -- 现代风格按钮
        function Modules:AddButton(txt, cb)
            local b = PaperUI:_make("TextButton", {
                Size = UDim2.new(1, 0, 0, 38),
                BackgroundColor3 = PaperUI.Themes.Card,
                Text = "",
                AutoButtonColor = false,
                Parent = Page
            })
            PaperUI:_make("UICorner", {CornerRadius = UDim.new(0, 8), Parent = b})
            local l = PaperUI:_make("TextLabel", {
                Size = UDim2.new(1, -20, 1, 0),
                Position = UDim2.new(0, 12, 0, 0),
                Text = txt,
                TextColor3 = PaperUI.Themes.Text,
                Font = Enum.Font.Gotham,
                TextSize = 13,
                TextXAlignment = "Left",
                BackgroundTransparency = 1,
                Parent = b
            })
            
            PaperUI:_addHover(b, {BackgroundColor3 = Color3.fromRGB(35, 35, 40)}, {BackgroundColor3 = PaperUI.Themes.Card})
            b.MouseButton1Down:Connect(function() 
                TS:Create(b, PaperUI.Anims.Quick, {Size = UDim2.new(1, -4, 0, 36)}):Play()
                cb()
                task.wait(0.1)
                TS:Create(b, PaperUI.Anims.Quick, {Size = UDim2.new(1, 0, 0, 38)}):Play()
            end)
        end

        -- 平滑滑动 Toggle
        function Modules:AddToggle(txt, def, cb)
            local state = def
            local t = PaperUI:_make("Frame", {Size = UDim2.new(1, 0, 0, 40), BackgroundColor3 = PaperUI.Themes.Card, Parent = Page})
            PaperUI:_make("UICorner", {CornerRadius = UDim.new(0, 8), Parent = t})
            
            local l = PaperUI:_make("TextLabel", {
                Size = UDim2.new(1, -60, 1, 0), Position = UDim2.new(0, 12, 0, 0),
                Text = txt, BackgroundTransparency = 1, TextColor3 = PaperUI.Themes.Text,
                Font = Enum.Font.Gotham, TextSize = 13, TextXAlignment = "Left", Parent = t
            })

            local Bg = PaperUI:_make("Frame", {
                Size = UDim2.new(0, 34, 0, 18), Position = UDim2.new(1, -45, 0.5, -9),
                BackgroundColor3 = state and PaperUI.Themes.Accent or Color3.fromRGB(50, 50, 55), Parent = t
            })
            PaperUI:_make("UICorner", {CornerRadius = UDim.new(1, 0), Parent = Bg})

            local Dot = PaperUI:_make("Frame", {
                Size = UDim2.new(0, 12, 0, 12),
                Position = state and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6),
                BackgroundColor3 = Color3.new(1, 1, 1), Parent = Bg
            })
            PaperUI:_make("UICorner", {CornerRadius = UDim.new(1, 0), Parent = Dot})

            local btn = PaperUI:_make("TextButton", {Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "", Parent = t})
            
            btn.MouseButton1Click:Connect(function()
                state = not state
                TS:Create(Bg, PaperUI.Anims.Quick, {BackgroundColor3 = state and PaperUI.Themes.Accent or Color3.fromRGB(50, 50, 55)}):Play()
                TS:Create(Dot, PaperUI.Anims.Quick, {Position = state and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6)}):Play()
                cb(state)
            end)
        end

        return Modules
    end

    return Tabs
end

return PaperUI